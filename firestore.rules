rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: bfScores
// Document ID: auto-generated
// Fields (exact set — no extras allowed):
//   - name: string (required, 1..16 chars) - display name
//   - score: number (required, integer 0..10,000,000) - final run score
//   - uid: string (required, must equal the writer's auth UID) - author
//   - createdAt: timestamp (required, server timestamp == request.time)
//
// Access model:
//   - read: PUBLIC (leaderboard is intentionally world-readable)
//   - create: authenticated (anonymous OK) + strict validation
//   - update/delete: DENIED (scores are immutable)
//
// NOTE: These are prototype rules. They enforce shape, ownership, and value
// ranges, but cannot prove a score was legitimately earned. Add App Check
// (and optionally a Cloud Function) to harden against forged scores.
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: only the allowed fields are present.
    function hasOnlyScoreFields() {
      return request.resource.data.keys().hasOnly(['name', 'score', 'uid', 'createdAt']);
    }

    // Helper: full validation of an incoming score document.
    function isValidScore() {
      let d = request.resource.data;
      return hasOnlyScoreFields()
        && d.keys().hasAll(['name', 'score', 'uid', 'createdAt'])
        && d.name is string && d.name.size() >= 1 && d.name.size() <= 16
        && d.score is number && d.score >= 0 && d.score <= 10000000
        && d.uid is string && d.uid == request.auth.uid
        && d.createdAt is timestamp && d.createdAt == request.time;
    }

    match /bfScores/{scoreId} {
      // Public leaderboard: anyone may read the scores.
      allow read: if true;

      // Authenticated (anonymous allowed), strictly validated, create-only.
      allow create: if request.auth != null && isValidScore();

      // Scores can never be edited or removed by clients.
      allow update, delete: if false;
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
